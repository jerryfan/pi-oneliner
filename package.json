{
  "name": "pi-oneliner",
  "version": "1.4.3",
  "description": "One-line sticky footer extension for pi coding agent.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerryfan/pi-oneliner.git"
  },
  "homepage": "https://github.com/jerryfan/pi-oneliner",
  "bugs": {
    "url": "https://github.com/jerryfan/pi-oneliner/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "statusline",
    "terminal-ui"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.ts",
    "locales/*.json",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "example.json"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  }
}
